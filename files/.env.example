# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# ── Google OAuth ───────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
# Must be a public URL if deploying to a server.
# Use http://localhost:8000/oauth/callback for local testing.
OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback

# ── Database ───────────────────────────────────────────────────
DB_PATH=data/aatas.db

# ── Trainer Mode ───────────────────────────────────────────────
# Secret code you type in Telegram to enter ML trainer mode: /train CODE
# Default is today's date — change this to anything you want.
TRAINER_SECRET_CODE=24426
